# Base URL for the backend API.
# In development this is left blank because vite.config.js proxies
# /api requests straight to http://localhost:5000 (see server.proxy).
# In production, set this to your deployed backend's full URL, e.g.
# VITE_API_BASE_URL=https://your-backend.onrender.com/api
VITE_API_BASE_URL=/api
